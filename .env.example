# Cloudflare R2 image CDN base URL (no trailing slash)
NEXT_PUBLIC_R2_BASE_URL=https://your-r2-domain.example.com

# Google Analytics
NEXT_PUBLIC_GA_ID=G-X5E0WH9Y43

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare R2 (private download delivery)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET=whatif-ep-xyz
# Optional override (defaults to https://<account-id>.r2.cloudflarestorage.com)
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
