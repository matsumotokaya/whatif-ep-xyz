# Cloudflare R2 image CDN base URL (no trailing slash)
NEXT_PUBLIC_R2_BASE_URL=https://your-r2-domain.example.com

# Google Analytics
NEXT_PUBLIC_GA_ID=G-X5E0WH9Y43

# Site origin used for absolute URLs (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://whatif-ep.xyz

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (server-only; required by the admin Supabase client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (wallpaper one-time purchase)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_WALLPAPER_PRICE_ID=price_1TkDEFQ2eK2Q8eWbGprRIoP2

# Transactional email notifications
RESEND_API_KEY=re_xxx
# Optional overrides
# RESEND_FROM_EMAIL=noreply@whatif-ep.xyz
# CONTACT_NOTIFICATION_EMAIL=contact@whatif-ep.xyz

# Cloudflare R2 (private download delivery)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET=whatif-ep-xyz
# Optional override (defaults to https://<account-id>.r2.cloudflarestorage.com)
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
